# Copy this file to .env and replace the placeholder values.

# GitHub Actions / AWS deployment secrets
AWS_ACCESS_KEY_ID=REPLACE_WITH_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_AWS_SECRET_ACCESS_KEY
AWS_REGION=eu-west-1

# ECS / ECR deployment settings
ECR_REPOSITORY=credit-risk-api
ECS_SERVICE=credit-risk-service
ECS_CLUSTER=credit-risk-cluster
CONTAINER_NAME=credit-risk-api
CONTAINER_PORT=8000

# Optional local-only values
API_BASE_URL=http://localhost:8000
